{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "helpers:pinGitHubActionDigests",
    ":dependencyDashboard"
  ],
  "schedule": ["before 9am on monday"],
  "timezone": "America/New_York",
  "prHourlyLimit": 0,
  "labels": ["dependencies"],
  "semanticCommits": "enabled",
  "semanticCommitType": "fix",
  "minimumReleaseAge": "14 days",
  "internalChecksFilter": "strict",
  "packageRules": [
    {
      "description": "Batch all non-major updates into one weekly PR.",
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "groupName": "non-major updates"
    },
    {
      "description": "Auto-merge GitHub Actions updates once CI passes — including the initial SHA pin and digest refreshes (actions are SHA-pinned via helpers:pinGitHubActionDigests).",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["pin", "minor", "patch", "digest"],
      "automerge": true
    },
    {
      "description": "Auto-merge patch updates to asdf-pinned tools (.tool-versions).",
      "matchManagers": ["asdf"],
      "matchUpdateTypes": ["patch"],
      "automerge": true
    },
    {
      "description": "Major bumps and Go module updates open a PR for review.",
      "matchManagers": ["gomod"],
      "automerge": false
    }
  ]
}
