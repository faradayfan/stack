#!/bin/sh
# Enforce Conventional Commits (https://www.conventionalcommits.org).
# Release Please parses these prefixes to compute the version + changelog, so a
# malformed message would silently skip a release. This rejects bad messages at
# commit time. Activate with: git config core.hooksPath .githooks
#
# Accepted: type(optional-scope)!: subject
#   types: feat fix docs style refactor perf test build ci chore revert
#   `!` and a `BREAKING CHANGE:` footer signal a major bump.

msg_file="$1"
# First non-comment, non-blank line is the subject.
subject="$(grep -v '^#' "$msg_file" | sed '/^[[:space:]]*$/d' | head -n1)"

# Let git's own machinery through (merge / revert / fixup / squash commits).
case "$subject" in
  "Merge "*|"Revert "*|"fixup! "*|"squash! "*|"Reapply "*)
    exit 0 ;;
esac

pattern='^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\([a-z0-9._/-]+\))?!?: .+'

if printf '%s' "$subject" | grep -Eq "$pattern"; then
  exit 0
fi

cat >&2 <<EOF
✗ Commit message does not follow Conventional Commits.

  got:    $subject

  format: <type>(<optional scope>): <subject>
  types:  feat fix docs style refactor perf test build ci chore revert
  e.g.    feat(engine): add podman build manifest
          fix: handle empty pipeline
          refactor(config)!: rename images to artifacts   # ! = breaking

Release Please uses this to compute versions and the changelog. See CONTRIBUTING.md.
EOF
exit 1
